<%- include('partials/header') %>

<div class="container">
  <div class="checkout-layout">
    
    <!-- Left: Prefilled Checkout Form -->
    <form action="/checkout/submit" method="POST" class="checkout-card">
      
      <!-- Delivery Details Section -->
      <h2 class="form-section-title">
        <span style="font-size: 1.3rem;">📦</span> Delivery Details
      </h2>
      
      <div class="checkout-grid">
        <div class="form-group full-width">
          <label for="name">Full Name</label>
          <input type="text" id="name" name="name" value="<%= user.name %>" required>
        </div>
        
        <div class="form-group full-width">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" value="<%= user.email %>" required>
        </div>
        
        <div class="form-group full-width">
          <label for="address">Shipping Address</label>
          <input type="text" id="address" name="address" value="<%= user.address %>" required>
        </div>
        
        <div class="form-group">
          <label for="city">City</label>
          <input type="text" id="city" name="city" value="<%= user.city %>" required>
        </div>
        
        <div class="form-group">
          <label for="zip">Zip / Postal Code</label>
          <input type="text" id="zip" name="zip" value="<%= user.zip %>" required>
        </div>
      </div>
      
      <!-- Payment Details Section -->
      <h2 class="form-section-title" style="margin-top: 40px;">
        <span style="font-size: 1.3rem;">💳</span> Secure Payment
      </h2>
      
      <!-- Animated / Stylized Visual Credit Card Face -->
      <div class="visual-card-face">
        <div class="card-top">
          <div class="card-chip"></div>
          <span class="card-brand">CANINE CARD</span>
        </div>
        
        <div class="card-number-display" id="cardNoDisplay"><%= user.cardNumber %></div>
        
        <div class="card-bottom">
          <div class="card-holder">
            <span class="card-label">Card Holder</span>
            <span class="card-value" id="cardNameDisplay"><%= user.cardName %></span>
          </div>
          <div class="card-expiry">
            <span class="card-label">Expires</span>
            <span class="card-value" id="cardExpiryDisplay"><%= user.cardExpiry %></span>
          </div>
        </div>
      </div>
      
      <div class="checkout-grid">
        <div class="form-group full-width">
          <label for="cardName">Name on Card</label>
          <input type="text" id="cardName" name="cardName" value="<%= user.cardName %>" required>
        </div>
        
        <div class="form-group full-width">
          <label for="cardNumber">Card Number</label>
          <input type="text" id="cardNumber" name="cardNumber" value="<%= user.cardNumber %>" required>
        </div>
        
        <div class="form-group">
          <label for="cardExpiry">Expiration Date</label>
          <input type="text" id="cardExpiry" name="cardExpiry" value="<%= user.cardExpiry %>" required placeholder="MM/YY">
        </div>
        
        <div class="form-group">
          <label for="cardCvc">CVC Code</label>
          <input type="password" id="cardCvc" name="cardCvc" value="<%= user.cardCvc %>" required placeholder="***">
        </div>
      </div>
      
      <!-- Instant Purchase Submit Button -->
      <button type="submit" class="btn btn-primary checkout-btn" style="width: 100%; padding: 18px; font-size: 1.2rem; border-radius: var(--radius-md); justify-content: center; margin-top: 24px;">
        Complete Secure Adoption 🐶🔒
      </button>
      
    </form>
    
    <!-- Right: Sidebar Order Details -->
    <div class="cart-summary-container">
      <h3 class="summary-title">Your Puppies</h3>
      
      <div class="checkout-items">
        <% cartItems.forEach(item => { %>
          <div class="checkout-item">
            <div>
              <span class="checkout-item-name"><%= item.product.name %></span>
              <span class="checkout-item-qty">x<%= item.quantity %></span>
            </div>
            <span style="font-weight: 600;">$<%= (item.product.price * item.quantity).toFixed(2) %></span>
          </div>
        <% }); %>
      </div>
      
      <div class="summary-row" style="border-top: 1px solid var(--border-cozy); padding-top: 16px;">
        <span>Subtotal</span>
        <span>$<%= subtotal.toFixed(2) %></span>
      </div>
      
      <div class="summary-row">
        <span>Courier Shipping</span>
        <span><%= shipping === 0 ? 'FREE' : '$' + shipping.toFixed(2) %></span>
      </div>
      
      <div class="summary-row total">
        <span>Grand Total</span>
        <span>$<%= total.toFixed(2) %></span>
      </div>
      
      <p style="font-size: 0.8rem; color: var(--text-muted); text-align: center; margin-top: 24px; font-family: var(--font-body);">
        🛡️ Payments are secured via 256-bit clay SSL encryption.
      </p>
    </div>
    
  </div>
</div>

<!-- Dynamic credit card syncing script -->
<script>
  const cardNoInput = document.getElementById('cardNumber');
  const cardNameInput = document.getElementById('cardName');
  const cardExpiryInput = document.getElementById('cardExpiry');
  
  const cardNoDisplay = document.getElementById('cardNoDisplay');
  const cardNameDisplay = document.getElementById('cardNameDisplay');
  const cardExpiryDisplay = document.getElementById('cardExpiryDisplay');
  
  cardNoInput.addEventListener('input', (e) => {
    cardNoDisplay.textContent = e.target.value || '4111 2222 3333 4444';
  });
  cardNameInput.addEventListener('input', (e) => {
    cardNameDisplay.textContent = (e.target.value || 'ARIA BENNETT').toUpperCase();
  });
  cardExpiryInput.addEventListener('input', (e) => {
    cardExpiryDisplay.textContent = e.target.value || '12/28';
  });
</script>

<%- include('partials/footer') %>
